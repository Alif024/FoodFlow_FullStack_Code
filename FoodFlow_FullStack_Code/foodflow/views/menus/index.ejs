<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Menus</h1>
  <a class="btn btn-primary" href="/menus/new">+ Add New</a>
</div>

<table class="table">
  <thead>
    <tr>
      <th>menu_id</th><th>menu_name</th><th>category_name</th><th>price</th><th>status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% menus.forEach(item => { %>
      <tr>
        <td><%= item.menu_id ?? '' %></td><td><%= item.menu_name ?? '' %></td><td><%= item.category_name ?? '' %></td><td><%= item.price ?? '' %></td><td><%= item.status ?? '' %></td>
        <td class="actions">
          <a class="btn btn-sm" href="/menus/<%= item.menu_id %>">View</a>
          <a class="btn btn-sm" href="/menus/<%= item.menu_id %>/edit">Edit</a>
          <form class="inline" method="POST" action="/menus/<%= item.menu_id %>?_method=DELETE" onsubmit="return confirm('ยืนยันการลบ?');">
            <button class="btn btn-sm btn-danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
