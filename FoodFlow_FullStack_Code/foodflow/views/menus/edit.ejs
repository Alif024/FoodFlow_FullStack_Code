<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Edit Menu</h1>
  <a class="btn" href="/menus/<%= menu.menu_id %>">← Back</a>
</div>

<form class="form" method="POST" action="/menus/<%= menu.menu_id %>?_method=PUT">
  <label>Menu Name
    <input name="menu_name" required maxlength="200" value="<%= menu.menu_name %>" />
  </label>
  <label>Category
    <input name="category_name" required maxlength="100" value="<%= menu.category_name %>" />
  </label>
  <label>Price
    <input name="price" type="number" step="0.01" min="0" required value="<%= menu.price %>" />
  </label>
  <label>Status
    <select name="status" required>
      <option value="available" <%= menu.status === 'available' ? 'selected' : '' %>>available</option>
      <option value="unavailable" <%= menu.status === 'unavailable' ? 'selected' : '' %>>unavailable</option>
    </select>
  </label>

  <div class="btn-row">
    <button class="btn btn-primary" type="submit">Update</button>
    <a class="btn" href="/menus/<%= menu.menu_id %>">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
