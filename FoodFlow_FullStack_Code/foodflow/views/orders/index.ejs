<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Orders</h1>
  <a class="btn btn-primary" href="/orders/new">+ Create Order</a>
</div>

<table class="table">
  <thead>
    <tr>
      <th>order_id</th>
      <th>customer</th>
      <th>order_date</th>
      <th>total_price</th>
      <th>order_status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% orders.forEach(o => { %>
      <tr>
        <td><%= o.order_id %></td>
        <td><%= o.Customer ? o.Customer.customer_name : '-' %></td>
        <td><%= o.order_date %></td>
        <td><%= o.total_price %></td>
        <td><%= o.order_status %></td>
        <td class="actions">
          <a class="btn btn-sm" href="/orders/<%= o.order_id %>">View</a>
          <a class="btn btn-sm" href="/orders/<%= o.order_id %>/edit">Edit</a>
          <form class="inline" method="POST" action="/orders/<%= o.order_id %>?_method=DELETE" onsubmit="return confirm('ยืนยันการลบ?');">
            <button class="btn btn-sm btn-danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
