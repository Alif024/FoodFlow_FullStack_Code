<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Order #<%= order.order_id %></h1>
  <div class="btn-row">
    <a class="btn" href="/orders">← Back</a>
    <a class="btn btn-primary" href="/orders/<%= order.order_id %>/edit">Edit</a>
    <a class="btn" href="/order-details/new">+ Add Item</a>
    <form class="inline" method="POST" action="/orders/<%= order.order_id %>?_method=DELETE" onsubmit="return confirm('ยืนยันการลบ?');">
      <button class="btn btn-danger" type="submit">Delete</button>
    </form>
  </div>
</div>

<div class="detail">
  <div class="detail-row"><span class="label">Customer</span><span class="value"><%= order.Customer ? order.Customer.customer_name : '-' %></span></div>
  <div class="detail-row"><span class="label">Date</span><span class="value"><%= order.order_date %></span></div>
  <div class="detail-row"><span class="label">Status</span><span class="value"><%= order.order_status %></span></div>
  <div class="detail-row"><span class="label">Total</span><span class="value"><%= order.total_price %></span></div>
</div>

<h2 class="mt">Items</h2>
<table class="table">
  <thead>
    <tr>
      <th>order_detail_id</th>
      <th>menu</th>
      <th>qty</th>
      <th>sub_total</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (order.OrderDetails && order.OrderDetails.length) { %>
      <% order.OrderDetails.forEach(od => { %>
        <tr>
          <td><%= od.order_detail_id %></td>
          <td><%= od.Menu ? od.Menu.menu_name : '-' %></td>
          <td><%= od.quantity %></td>
          <td><%= od.sub_total %></td>
          <td class="actions">
            <a class="btn btn-sm" href="/order-details/<%= od.order_detail_id %>">View</a>
            <a class="btn btn-sm" href="/order-details/<%= od.order_detail_id %>/edit">Edit</a>
          </td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr><td colspan="5" class="muted">ยังไม่มีรายการอาหาร</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('../partials/footer') %>
