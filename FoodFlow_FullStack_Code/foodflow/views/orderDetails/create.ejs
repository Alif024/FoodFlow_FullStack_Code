<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Add Order Detail</h1>
  <a class="btn" href="/order-details">← Back</a>
</div>

<form class="form" method="POST" action="/order-details">
  <label>Order
    <select name="order_id" required>
      <option value="">-- เลือกออเดอร์ --</option>
      <% orders.forEach(o => { %>
        <option value="<%= o.order_id %>">#<%= o.order_id %> • <%= o.Customer ? o.Customer.customer_name : '-' %> • <%= o.order_date %></option>
      <% }) %>
    </select>
  </label>

  <label>Menu
    <select name="menu_id" required>
      <option value="">-- เลือกเมนู --</option>
      <% menus.forEach(m => { %>
        <option value="<%= m.menu_id %>"><%= m.menu_name %> (฿<%= m.price %>)</option>
      <% }) %>
    </select>
  </label>

  <label>Quantity
    <input name="quantity" type="number" min="1" step="1" required value="1" />
  </label>

  <div class="note">
    ระบบจะคำนวณ sub_total = price × quantity ให้ และอัปเดต total_price ของ Order อัตโนมัติ
  </div>

  <div class="btn-row">
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn" href="/order-details">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
