<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>OrderDetail #<%= orderDetail.order_detail_id %></h1>
  <div class="btn-row">
    <a class="btn" href="/order-details">← Back</a>
    <a class="btn btn-primary" href="/order-details/<%= orderDetail.order_detail_id %>/edit">Edit</a>
    <form class="inline" method="POST" action="/order-details/<%= orderDetail.order_detail_id %>?_method=DELETE" onsubmit="return confirm('ยืนยันการลบ?');">
      <button class="btn btn-danger" type="submit">Delete</button>
    </form>
  </div>
</div>

<div class="detail">
  <div class="detail-row"><span class="label">Order</span><span class="value">#<%= orderDetail.order_id %></span></div>
  <div class="detail-row"><span class="label">Customer</span><span class="value"><%= orderDetail.Order && orderDetail.Order.Customer ? orderDetail.Order.Customer.customer_name : '-' %></span></div>
  <div class="detail-row"><span class="label">Menu</span><span class="value"><%= orderDetail.Menu ? orderDetail.Menu.menu_name : '-' %></span></div>
  <div class="detail-row"><span class="label">Quantity</span><span class="value"><%= orderDetail.quantity %></span></div>
  <div class="detail-row"><span class="label">Sub Total</span><span class="value"><%= orderDetail.sub_total %></span></div>
</div>

<%- include('../partials/footer') %>
