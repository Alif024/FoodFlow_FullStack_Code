<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | FoodFlow</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="navbar">
    <div class="container nav-inner">
      <a class="brand" href="/">FoodFlow</a>
      <nav class="nav-links">
        <a href="/menus" class="<%= path.startsWith('/menus') ? 'active' : '' %>">Menus</a>
        <a href="/customers" class="<%= path.startsWith('/customers') ? 'active' : '' %>">Customers</a>
        <a href="/orders" class="<%= path.startsWith('/orders') ? 'active' : '' %>">Orders</a>
        <a href="/order-details" class="<%= path.startsWith('/order-details') ? 'active' : '' %>">OrderDetails</a>
        <div class="dropdown">
          <span class="dropbtn">Reports ▾</span>
          <div class="dropdown-content">
            <a href="/reports/sales">Sales Report</a>
            <a href="/reports/top-menus">Top Menus</a>
          </div>
        </div>
      </nav>
    </div>
  </header>

  <main class="container content">
    <% if (success && success.length) { %>
      <div class="flash flash-success"><%= success[0] %></div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="flash flash-error"><%= error[0] %></div>
    <% } %>
