<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Customers</h1>
  <a class="btn btn-primary" href="/customers/new">+ Add New</a>
</div>

<table class="table">
  <thead>
    <tr>
      <th>customer_id</th><th>customer_name</th><th>phone</th><th>email</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% customers.forEach(item => { %>
      <tr>
        <td><%= item.customer_id ?? '' %></td><td><%= item.customer_name ?? '' %></td><td><%= item.phone ?? '' %></td><td><%= item.email ?? '' %></td>
        <td class="actions">
          <a class="btn btn-sm" href="/customers/<%= item.customer_id %>">View</a>
          <a class="btn btn-sm" href="/customers/<%= item.customer_id %>/edit">Edit</a>
          <form class="inline" method="POST" action="/customers/<%= item.customer_id %>?_method=DELETE" onsubmit="return confirm('ยืนยันการลบ?');">
            <button class="btn btn-sm btn-danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
