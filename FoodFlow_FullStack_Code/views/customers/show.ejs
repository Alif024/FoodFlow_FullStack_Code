<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Customer Detail</h1>
  <div class="btn-row">
    <a class="btn" href="/customers">← Back</a>
    <a class="btn btn-primary" href="/customers/<%= customer.customer_id %>/edit">Edit</a>
    <form class="inline" method="POST" action="/customers/<%= customer.customer_id %>?_method=DELETE" onsubmit="return confirm('ยืนยันการลบ?');">
      <button class="btn btn-danger" type="submit">Delete</button>
    </form>
  </div>
</div>

<div class="detail">
  <div class='detail-row'><span class='label'>customer_id</span><span class='value'><%= customer.customer_id ?? '' %></span></div><div class='detail-row'><span class='label'>customer_name</span><span class='value'><%= customer.customer_name ?? '' %></span></div><div class='detail-row'><span class='label'>phone</span><span class='value'><%= customer.phone ?? '' %></span></div><div class='detail-row'><span class='label'>email</span><span class='value'><%= customer.email ?? '' %></span></div>
</div>

<%- include('../partials/footer') %>
