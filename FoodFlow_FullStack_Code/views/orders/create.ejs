<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Create Order</h1>
  <a class="btn" href="/orders">← Back</a>
</div>

<form class="form" method="POST" action="/orders">
  <label>Customer
    <select name="customer_id" required>
      <option value="">-- เลือกลูกค้า --</option>
      <% customers.forEach(c => { %>
        <option value="<%= c.customer_id %>"><%= c.customer_name %> (#<%= c.customer_id %>)</option>
      <% }) %>
    </select>
  </label>

  <label>Order Date
    <input name="order_date" type="date" required />
  </label>

  <label>Status
    <select name="order_status" required>
      <option value="pending">pending</option>
      <option value="paid">paid</option>
      <option value="cancelled">cancelled</option>
    </select>
  </label>

  <div class="note">
    หลังสร้างออเดอร์แล้ว ให้เพิ่มรายการอาหารที่หน้า <a href="/order-details/new">OrderDetails</a>
  </div>

  <div class="btn-row">
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn" href="/orders">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
