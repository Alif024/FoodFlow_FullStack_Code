<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>OrderDetails</h1>
  <a class="btn btn-primary" href="/order-details/new">+ Add Item</a>
</div>

<table class="table">
  <thead>
    <tr>
      <th>order_detail_id</th>
      <th>order</th>
      <th>customer</th>
      <th>menu</th>
      <th>qty</th>
      <th>sub_total</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% orderDetails.forEach(od => { %>
      <tr>
        <td><%= od.order_detail_id %></td>
        <td>#<%= od.order_id %></td>
        <td><%= od.Order && od.Order.Customer ? od.Order.Customer.customer_name : '-' %></td>
        <td><%= od.Menu ? od.Menu.menu_name : '-' %></td>
        <td><%= od.quantity %></td>
        <td><%= od.sub_total %></td>
        <td class="actions">
          <a class="btn btn-sm" href="/order-details/<%= od.order_detail_id %>">View</a>
          <a class="btn btn-sm" href="/order-details/<%= od.order_detail_id %>/edit">Edit</a>
          <form class="inline" method="POST" action="/order-details/<%= od.order_detail_id %>?_method=DELETE" onsubmit="return confirm('ยืนยันการลบ?');">
            <button class="btn btn-sm btn-danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
