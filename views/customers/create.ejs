<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Add Customer</h1>
  <a class="btn" href="/customers">← Back</a>
</div>

<form class="form" method="POST" action="/customers">
  <label>Name
    <input name="customer_name" required maxlength="200" />
  </label>
  <label>Phone
    <input name="phone" maxlength="30" />
  </label>
  <label>Email
    <input name="email" type="email" maxlength="200" />
  </label>

  <div class="btn-row">
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn" href="/customers">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
