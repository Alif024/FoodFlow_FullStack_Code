<div class="tab-panel active" id="menu">
  <div class="panel-header">
    <span class="panel-badge">Order Menu</span>
    <h1 class="panel-title">Menu</h1>
    <p class="panel-description">Pick your best-sellers and seasonal plates. Colors, badges, and buttons reuse the shared theme tokens so the menu feels native to the dashboard.</p>
  </div>
  <div class="panel-content menu-layout">
    <div class="menu-grid">
      <article class="menu-card" style="--menu-accent: var(--idx-accent);">
        <div class="menu-card__image">
          <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?auto=format&fit=crop&w=800&q=80" alt="Fire-roasted salmon bowl" loading="lazy">
          <span class="menu-card__badge">Bestseller</span>
        </div>
        <div class="menu-card__body">
          <div class="menu-card__heading">
            <h3 class="menu-card__name">Fire-Roasted Salmon</h3>
            <span class="menu-card__price">$18.50</span>
          </div>
          <p class="menu-card__desc">Charred salmon over citrus grains, wilted greens, and smoked chili beurre blanc.</p>
          <div class="menu-card__meta">
            <span class="menu-card__tag">High protein</span>
            <span class="menu-card__tag">Gluten free</span>
          </div>
        </div>
        <div class="menu-card__footer">
          <span class="menu-card__rating">4.9 ★</span>
          <button class="menu-card__cta">Add to order</button>
        </div>
      </article>
    </div>
  </div>
</div>
