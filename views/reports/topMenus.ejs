<%- include('../partials/header', { title }) %>

<div class="page-head">
  <h1>Top Menus Report</h1>
</div>

<form class="form form-inline" method="GET" action="/reports/top-menus">
  <label>Limit
    <input type="number" name="limit" min="1" max="50" value="<%= limit %>" />
  </label>
  <button class="btn btn-primary" type="submit">Apply</button>
</form>

<div class="stats">
  <div class="stat"><div class="stat-label">Total Qty (shown)</div><div class="stat-value"><%= summary.qty %></div></div>
  <div class="stat"><div class="stat-label">Total Sales (shown)</div><div class="stat-value"><%= summary.sales.toFixed(2) %></div></div>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Menu</th>
      <th>Category</th>
      <th>Total Qty</th>
      <th>Total Sales</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% if (rows.length) { %>
      <% rows.forEach(r => { %>
        <tr>
          <td><%= r.Menu ? r.Menu.menu_name : '-' %></td>
          <td><%= r.Menu ? r.Menu.category_name : '-' %></td>
          <td><%= r.get('total_qty') %></td>
          <td><%= Number(r.get('total_sales') || 0).toFixed(2) %></td>
          <td><%= r.Menu ? r.Menu.status : '-' %></td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr><td colspan="5" class="muted">ยังไม่มีรายการสั่งอาหาร</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('../partials/footer') %>
